# .env.example

# Ambiente (development ou production)
NODE_ENV=development

# Para desenvolvimento local com Docker Compose
DATABASE_URL="postgresql://orkestrya:orkestrya@postgres:5432/orkestrya_db?schema=public"

# Para Coolify (ajuste as credenciais conforme o serviço PostgreSQL no Coolify)
# NODE_ENV=production
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public"